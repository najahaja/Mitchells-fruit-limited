# Mitchell's Fruit Limited — backend environment variables
# Copy to backend/.env and fill in values before running the API.

# ── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL async URL. Append +asyncpg to the postgresql:// scheme.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mitchells_db

# ── JWT / auth (required) ─────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for all.
CORS_ORIGINS=*

# ── Retell AI (required for voice agent) ──────────────────────────────────────
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_AGENT_ID=
RETELL_CONVERSATION_FLOW_ID=

# Outbound calling (optional — falls back to RETELL_AGENT_ID if unset)
RETELL_OUTBOUND_AGENT_ID=
# Retell-owned E.164 number used as caller ID for outbound dials
RETELL_PHONE_NUMBER=

# ── Email / password reset (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FRONTEND_URL=http://localhost:3000

# ── Clover POS (optional — leave blank to disable sync and order push) ────────
CLOVER_API_TOKEN=
CLOVER_MERCHANT_ID=
CLOVER_BASE_URL=https://api.clover.com/v3
CLOVER_ORDER_TYPE_ID=
